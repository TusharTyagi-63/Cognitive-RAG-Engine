# ==============================================================================
# Docker Ignore — Cognitive RAG Engine
# Prevents leaking secrets, caches, and dev artifacts into the image.
# ==============================================================================

# Secrets
.env
.env.*
!.env.example

# Python caches
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Virtual environments
.venv/
venv/
env/

# Tests & coverage
.pytest_cache/
.coverage
htmlcov/
tests/

# IDE & OS
.idea/
.vscode/
.DS_Store
*.swp

# Logs
logs/
*.log

# Git
.git/
.gitignore

# Docker itself
Dockerfile
docker-compose*.yml
.dockerignore

# Documentation
*.md
docs/
