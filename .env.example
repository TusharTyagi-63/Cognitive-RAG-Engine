# ==============================================================================
# Cognitive RAG Engine — Environment Variable Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ==============================================================================

# ------------------------------------------------------------------------------
# Application
# ------------------------------------------------------------------------------
APP_NAME="Cognitive RAG Engine"
APP_VERSION="0.1.0"
APP_ENV="development"          # development | staging | production
DEBUG=true
LOG_LEVEL="INFO"               # DEBUG | INFO | WARNING | ERROR | CRITICAL

# ------------------------------------------------------------------------------
# API
# ------------------------------------------------------------------------------
API_V1_PREFIX="/api/v1"
ALLOWED_ORIGINS='["http://localhost:3000","http://localhost:5173"]'

# ------------------------------------------------------------------------------
# Database (PostgreSQL)
# ------------------------------------------------------------------------------
POSTGRES_HOST="localhost"
POSTGRES_PORT=5432
POSTGRES_DB="rag_platform"
POSTGRES_USER="rag_user"
POSTGRES_PASSWORD="your_strong_password_here"

# Derived — overrides individual fields if set directly
# DATABASE_URL="postgresql+asyncpg://rag_user:password@localhost:5432/rag_platform"

# Connection pool
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# ------------------------------------------------------------------------------
# Security / JWT  (to be used in a later phase)
# ------------------------------------------------------------------------------
SECRET_KEY="change-me-to-a-long-random-string-at-least-32-chars"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
